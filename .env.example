# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Kalshi API credentials
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your-private-key-here
-----END RSA PRIVATE KEY-----"

# Database (overrides config.yaml value if set)
DATABASE_URL=postgresql://kalshi_bot:kalshi_bot@postgres:5432/kalshi_bot

# Set to "production" to use live Kalshi API, anything else uses demo
ENVIRONMENT=development
